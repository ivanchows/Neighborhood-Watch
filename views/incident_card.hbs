<main>
  <section style="padding: 80px 0;">
    <div class="container" style="max-width: 760px;">

      <div style="margin-bottom: 32px;">
        <a href="/incidents" style="color: var(--text-muted); text-decoration: none; font-size: 13px;">← Back to incidents</a>
      </div>

      <div class="panel" style="padding: 36px;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
          <span class="badge {{statusClass incident.status}}">{{incident.status}}</span>
          {{#if incident.verified}}
            <span class="badge" style="color: var(--green); border-color: var(--green);">Verified</span>
          {{/if}}
          <span style="font-size: 12px; color: var(--text-muted);">{{incident.postedDate}}</span>
        </div>

        <h1 style="font-family: 'Instrument Serif', serif; font-weight: 400; font-size: clamp(28px, 4vw, 42px); letter-spacing: -0.02em; margin-bottom: 8px;">{{incident.Title}}</h1>
        <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 28px;">{{incident.location}}</p>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 6px; margin-bottom: 28px;">
          <div style="background: var(--surface-2); padding: 16px 20px;">
            <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">Category</div>
            <div style="font-size: 14px;">{{incident.category}}</div>
          </div>
          <div style="background: var(--surface-2); padding: 16px 20px;">
            <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">Reported by</div>
            <div style="font-size: 14px;">{{incident.reportedBy}}</div>
          </div>
          <div style="background: var(--surface-2); padding: 16px 20px;">
            <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">Verifications</div>
            <div style="font-size: 14px;">{{incident.verified}}</div>
          </div>
        </div>

        <p style="font-size: 15px; line-height: 1.7; color: var(--text); margin-bottom: 32px;">{{incident.description}}</p>

        {{#if isOwner}}
        <div style="display: flex; gap: 10px; flex-wrap: wrap; padding-top: 24px; border-top: 1px solid var(--border);">
          <a href="/incident_update/{{incident._id}}" class="btn btn-ghost" style="font-size: 13px;">Edit</a>
          <a href="/status/{{incident._id}}" class="btn btn-ghost" style="font-size: 13px;">Update Status</a>
          <form action="/incident_card/{{incident._id}}" method="POST" style="margin: 0;">
            <button type="submit" class="btn" style="font-size: 13px; background: transparent; border: 1px solid var(--red); color: var(--red); border-radius: 6px; padding: 12px 22px; cursor: pointer;">Delete</button>
          </form>
        </div>
        {{/if}}

        {{#if admin}}
        <div style="display: flex; gap: 10px; flex-wrap: wrap; padding-top: 24px; border-top: 1px solid var(--border); margin-top: {{#if isOwner}}12px{{else}}0px{{/if}};">
          <a href="/verify/{{incident._id}}" class="btn btn-ghost" style="font-size: 13px;">Verify</a>
          <a href="/status/{{incident._id}}" class="btn btn-ghost" style="font-size: 13px;">Update Status</a>
          <form action="/incident_card/{{incident._id}}" method="POST" style="margin: 0;">
            <button type="submit" class="btn" style="font-size: 13px; background: transparent; border: 1px solid var(--red); color: var(--red); border-radius: 6px; padding: 12px 22px; cursor: pointer;">Delete (Admin)</button>
          </form>
        </div>
        {{/if}}
      </div>

    </div>
  </section>
</main>
