<main>
  <section style="padding: 80px 0; min-height: 70vh;">
    <div class="container" style="max-width: 520px;">
      <div class="section-eyebrow">// Get Started</div>
      <h2 class="section-title">Create your <em>account.</em></h2>

      {{#if hasError}}
        <p style="color: var(--red); margin-bottom: 20px;">{{error}}</p>
      {{/if}}

      <form id="signup-form" name="signup-form" method="POST" action="/register" style="display:flex; flex-direction:column; gap:14px;">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
          <div>
            <label for="firstName" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">First Name</label>
            <input type="text" id="firstName" name="firstName" placeholder="First Name"
              style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
          </div>
          <div>
            <label for="lastName" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">Last Name</label>
            <input type="text" id="lastName" name="lastName" placeholder="Last Name"
              style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
          </div>
        </div>

        <div>
          <label for="email" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">Email</label>
          <input type="email" id="email" name="email" placeholder="you@example.com"
            style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
          <div>
            <label for="gender" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">Gender</label>
            <select id="gender" name="gender"
              style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
              <option value="M">Male</option>
              <option value="F">Female</option>
              <option value="NB">Non-binary</option>
              <option value="prefer not to say">Prefer not to say</option>
            </select>
          </div>
          <div>
            <label for="age" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">Age</label>
            <input type="number" id="age" name="age" placeholder="Age" min="16" max="100"
              style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
          </div>
        </div>

        <div>
          <label style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">Street Address</label>
          <input type="text" id="Street" name="address[Street]" placeholder="123 Main St"
            style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
        </div>

        <div style="display:grid; grid-template-columns:1fr 80px 100px; gap:14px;">
          <div>
            <label for="City" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">City</label>
            <input type="text" id="City" name="address[City]" placeholder="City"
              style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
          </div>
          <div>
            <label for="State" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">State</label>
            <input type="text" id="State" name="address[State]" placeholder="NJ" maxlength="2"
              style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
          </div>
          <div>
            <label for="zipCode" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">ZIP</label>
            <input type="text" id="zipCode" name="address[zipCode]" placeholder="07030" maxlength="5"
              style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
          </div>
        </div>

        <div>
          <label for="password" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">Password</label>
          <input type="password" id="password" name="password" placeholder="Password"
            style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
        </div>

        <div>
          <label for="confirmPassword" style="display:block; margin-bottom:6px; color:var(--text-muted); font-size:13px;">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm Password"
            style="width:100%; padding:11px 13px; background:var(--surface); border:1px solid var(--border); color:var(--text); font-size:14px; border-radius:6px; outline:none;">
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; margin-top:4px;">Create Account</button>
      </form>

      <p style="margin-top:24px; color:var(--text-muted); font-size:14px;">
        Already have an account? <a href="/signin" style="color:var(--blue-bright);">Sign in</a>
      </p>
    </div>
  </section>
</main>
