<main>
  <section style="padding: 80px 0;">
    <div class="container" style="max-width: 480px;">
      <div style="margin-bottom: 24px;">
        <a href="/incident_card/{{incident._id}}" style="color: var(--text-muted); text-decoration: none; font-size: 13px;">← Back</a>
      </div>
      <div class="panel" style="padding: 32px;">
        <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 24px;">Verify Incident</h2>
        <form action="/verify/{{incident._id}}" method="POST">
          <div style="margin-bottom: 20px;">
            <label for="verified" style="display: block; font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">Verified?</label>
            <select name="verified" id="verified" style="width: 100%; padding: 10px 12px; background: var(--surface); border: 1px solid var(--border); color: var(--text); font-size: 14px; border-radius: 6px; outline: none;">
              <option value="yes">Yes</option>
              <option value="no">No</option>
            </select>
          </div>
          <button type="submit" name="submit_button" id="submit_button" class="btn btn-primary" style="width: 100%;">Submit</button>
        </form>
      </div>
    </div>
  </section>
</main>
