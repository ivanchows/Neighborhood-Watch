<main>
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div>
          <div class="hero-eyebrow">
            <span class="live-dot"></span>
            <span>Community Safety Intelligence</span>
          </div>
          <h1 class="hero-title">A neighborhood that <em>watches itself.</em></h1>
          <p class="hero-sub">Sentry connects residents with local services and each other — turning passive observation into active, coordinated community protection.</p>
          <div class="hero-cta">
            <a href="/register" class="btn btn-primary">Create Account →</a>
            <a href="#live" class="btn btn-ghost">View Live Map</a>
          </div>
        </div>
        <div class="radar">
          <svg viewBox="0 0 400 400">
            <defs>
              <radialGradient id="radarGlow">
                <stop offset="0%" stop-color="#4169E1" stop-opacity="0.2"/>
                <stop offset="100%" stop-color="#4169E1" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <circle cx="200" cy="200" r="180" fill="url(#radarGlow)"/>
            <circle cx="200" cy="200" r="180" fill="none" stroke="#1f242c" stroke-width="1"/>
            <circle cx="200" cy="200" r="135" fill="none" stroke="#1f242c" stroke-width="1"/>
            <circle cx="200" cy="200" r="90" fill="none" stroke="#1f242c" stroke-width="1"/>
            <circle cx="200" cy="200" r="45" fill="none" stroke="#1f242c" stroke-width="1"/>
            <line x1="20" y1="200" x2="380" y2="200" stroke="#1f242c" stroke-width="1"/>
            <line x1="200" y1="20" x2="200" y2="380" stroke="#1f242c" stroke-width="1"/>
            <line x1="73" y1="73" x2="327" y2="327" stroke="#1f242c" stroke-width="1"/>
            <line x1="73" y1="327" x2="327" y2="73" stroke="#1f242c" stroke-width="1"/>
            <circle cx="282" cy="138" r="5" fill="#4169E1"/>
            <circle cx="282" cy="138" r="5" fill="none" stroke="#4169E1" stroke-width="1.5">
              <animate attributeName="r" from="5" to="22" dur="2.4s" repeatCount="indefinite"/>
              <animate attributeName="opacity" from="0.8" to="0" dur="2.4s" repeatCount="indefinite"/>
            </circle>
            <circle cx="135" cy="245" r="5" fill="#F4A847"/>
            <circle cx="135" cy="245" r="5" fill="none" stroke="#F4A847" stroke-width="1.5">
              <animate attributeName="r" from="5" to="22" dur="2.4s" begin="0.7s" repeatCount="indefinite"/>
              <animate attributeName="opacity" from="0.8" to="0" dur="2.4s" begin="0.7s" repeatCount="indefinite"/>
            </circle>
            <circle cx="248" cy="282" r="5" fill="#4169E1"/>
            <circle cx="248" cy="282" r="5" fill="none" stroke="#4169E1" stroke-width="1.5">
              <animate attributeName="r" from="5" to="22" dur="2.4s" begin="1.4s" repeatCount="indefinite"/>
              <animate attributeName="opacity" from="0.8" to="0" dur="2.4s" begin="1.4s" repeatCount="indefinite"/>
            </circle>
            <circle cx="200" cy="200" r="3" fill="#7A93EB"/>
            <circle cx="200" cy="200" r="6" fill="none" stroke="#7A93EB" stroke-width="1" opacity="0.5"/>
          </svg>
          <div class="radar-sweep"></div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="stats">
      <div class="stat">
        <div class="stat-num">2,847</div>
        <div class="stat-label">Active Watchers</div>
      </div>
      <div class="stat">
        <div class="stat-num">98.4%</div>
        <div class="stat-label">Verified Reports</div>
      </div>
      <div class="stat">
        <div class="stat-num">&lt; 90s</div>
        <div class="stat-label">Median Alert Time</div>
      </div>
      <div class="stat">
        <div class="stat-num">24 / 7</div>
        <div class="stat-label">Coverage</div>
      </div>
    </div>
  </div>

  <section id="live">
    <div class="container">
      <div class="section-eyebrow">// Live Activity</div>
      <h2 class="section-title">Real-time view of <em>your block.</em></h2>
      <p class="section-lede">Every report is geolocated, verified by neighbors, and delivered with proximity-aware alerts. Powered by Google Maps.</p>

      <div class="live-grid">
        <div class="panel">
          <div class="panel-header">
            <span>Community Map · Hoboken, NJ</span>
            <span class="panel-status"><span class="live-dot"></span>LIVE</span>
          </div>
          <div class="map-area">
            <svg viewBox="0 0 600 450" style="position:absolute;inset:0;width:100%;height:100%;">
              <defs>
                <pattern id="streets" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
                  <path d="M 80 0 L 0 0 0 80" fill="none" stroke="#1f242c" stroke-width="1"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#streets)"/>
              <line x1="0" y1="180" x2="600" y2="180" stroke="#2a3140" stroke-width="3"/>
              <line x1="240" y1="0" x2="240" y2="450" stroke="#2a3140" stroke-width="3"/>
              <line x1="0" y1="340" x2="600" y2="340" stroke="#2a3140" stroke-width="2"/>
              <rect x="320" y="40" width="120" height="100" fill="#0d2419" opacity="0.55"/>
              <rect x="60" y="280" width="80" height="50" fill="#0d2419" opacity="0.55"/>
            </svg>
            <div class="map-pin" data-incident="0" style="top:32%; left:42%;"></div>
            <div class="map-pin amber" data-incident="1" style="top:58%; left:28%;"></div>
            <div class="map-pin" data-incident="2" style="top:71%; left:65%;"></div>
            <div class="map-pin red" data-incident="3" style="top:24%; left:72%;"></div>
            <div class="map-pin" data-incident="4" style="top:48%; left:80%;"></div>
            <div class="map-overlay">Lat <span>40.7440</span>  Lng <span>-74.0324</span></div>
            <div class="map-hint">Click any pin →</div>
          </div>
        </div>

        <div class="panel feed">
          <div class="panel-header">
            <span>Incident Feed</span>
            <span>5 reports</span>
          </div>
          <div class="feed-list">
            <div class="feed-item" data-incident="0">
              <div class="feed-meta">
                <span class="badge badge-active">ACTIVE</span>
                <span>2 min ago · 0.3 mi</span>
              </div>
              <div class="feed-title">Suspicious vehicle parked overnight</div>
              <div class="feed-loc">Washington St &amp; 7th St</div>
            </div>
            <div class="feed-item" data-incident="1">
              <div class="feed-meta">
                <span class="badge badge-notified">NOTIFIED</span>
                <span>14 min ago · 0.5 mi</span>
              </div>
              <div class="feed-title">Loose dog reported near Pier A</div>
              <div class="feed-loc">Pier A Park, NW corner</div>
            </div>
            <div class="feed-item" data-incident="2">
              <div class="feed-meta">
                <span class="badge badge-active">ACTIVE</span>
                <span>22 min ago · 0.8 mi</span>
              </div>
              <div class="feed-title">Power outage on block</div>
              <div class="feed-loc">Hudson St btwn 4th – 5th</div>
            </div>
            <div class="feed-item" data-incident="3">
              <div class="feed-meta">
                <span class="badge badge-resolved">RESOLVED</span>
                <span>1 hr ago · 1.2 mi</span>
              </div>
              <div class="feed-title">Minor traffic incident, fender bender</div>
              <div class="feed-loc">Observer Hwy &amp; Newark St</div>
            </div>
            <div class="feed-item" data-incident="4">
              <div class="feed-meta">
                <span class="badge badge-resolved">RESOLVED</span>
                <span>3 hr ago · 0.7 mi</span>
              </div>
              <div class="feed-title">Package theft — suspect identified</div>
              <div class="feed-loc">Garden St residential block</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features">
    <div class="container">
      <div class="section-eyebrow">// Core Features</div>
      <h2 class="section-title">Everything a vigilant neighborhood <em>needs.</em></h2>

      <div class="feat-grid">
        <div class="feat">
          <div class="feat-num">01 / 06</div>
          <div class="feat-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </div>
          <h3>Safety Dashboard</h3>
          <p>An at-a-glance landing page with recent verified alerts, your watchlist, and today's priorities for the block.</p>
        </div>
        <div class="feat">
          <div class="feat-num">02 / 06</div>
          <div class="feat-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
          </div>
          <h3>User Profile</h3>
          <p>Personal account with report history, watchlist, inbox, and a community trust rating earned through accurate reporting.</p>
        </div>
        <div class="feat">
          <div class="feat-num">03 / 06</div>
          <div class="feat-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C8 2 5 5 5 9c0 5 7 13 7 13s7-8 7-13c0-4-3-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          </div>
          <h3>Map &amp; Feed</h3>
          <p>Interactive map with geolocated pins, filterable incident feed, and one-tap quick reporting from your current location.</p>
        </div>
        <div class="feat">
          <div class="feat-num">04 / 06</div>
          <div class="feat-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="3" width="16" height="18"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/></svg>
          </div>
          <h3>Incident Cards</h3>
          <p>Detailed report views with media galleries, status tracking, neighbor verification, and threaded discussion.</p>
        </div>
        <div class="feat">
          <div class="feat-num">05 / 06</div>
          <div class="feat-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
          </div>
          <h3>Proximity Alerts</h3>
          <p>Real-time push notifications when something happens near you, your home, or any address in your watchlist.</p>
        </div>
        <div class="feat">
          <div class="feat-num">06 / 06</div>
          <div class="feat-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4z"/></svg>
          </div>
          <h3>Moderation Layer</h3>
          <p>Admin review tools, community flagging, and the ability to escalate verified reports into high-alert broadcasts.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="compare">
    <div class="container">
      <div class="section-eyebrow">// Why Sentry</div>
      <h2 class="section-title">The line between <em>noise</em> and <em>signal.</em></h2>
      <p class="section-lede">Existing apps over-correct in either direction — too casual to trust, or too alarming to live with. Sentry strikes the balance.</p>

      <div class="compare">
        <div class="compare-row head">
          <div class="compare-cell"></div>
          <div class="compare-cell us">SENTRY</div>
          <div class="compare-cell">NEXTDOOR</div>
          <div class="compare-cell">CITIZEN</div>
        </div>
        <div class="compare-row">
          <div class="compare-cell" style="color:var(--text-muted)">Verified reports</div>
          <div class="compare-cell check">✓  Admin + neighbor</div>
          <div class="compare-cell partial">Light moderation</div>
          <div class="compare-cell partial">Inconsistent</div>
        </div>
        <div class="compare-row">
          <div class="compare-cell" style="color:var(--text-muted)">Anxiety calibration</div>
          <div class="compare-cell check">✓  Balanced tone</div>
          <div class="compare-cell partial">Casual / off-topic</div>
          <div class="compare-cell cross">High / alarmist</div>
        </div>
        <div class="compare-row">
          <div class="compare-cell" style="color:var(--text-muted)">Proactive routing</div>
          <div class="compare-cell check">✓  Safe-path engine</div>
          <div class="compare-cell cross">—</div>
          <div class="compare-cell cross">—</div>
        </div>
        <div class="compare-row">
          <div class="compare-cell" style="color:var(--text-muted)">Local services link</div>
          <div class="compare-cell check">✓  Direct contact</div>
          <div class="compare-cell cross">—</div>
          <div class="compare-cell partial">Live updates only</div>
        </div>
      </div>

      <div class="cta-block" id="about">
        <h2 class="section-title" style="margin: 0 auto 16px; text-align:center;">Be the eyes <em>of your block.</em></h2>
        <p style="color:var(--text-muted); max-width:520px; margin: 0 auto 32px;">Join the watch. Verify what matters. Sleep a little easier.</p>
        <a href="/register" class="btn btn-primary">Request Early Access →</a>
      </div>
    </div>
  </section>
</main>

{{> incident-modal}}

<script type="module" src="/js/home.js"></script>
