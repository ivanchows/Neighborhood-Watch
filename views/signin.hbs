<main>
  <section style="padding: 100px 0; min-height: 70vh;">
    <div class="container" style="max-width: 480px;">
      <div class="section-eyebrow">// Welcome Back</div>
      <h2 class="section-title">Sign <em>in.</em></h2>
      <p class="section-lede" style="margin-bottom: 40px;">
        Access your neighborhood safety dashboard.
      </p>

      {{#if hasError}}
        <div class="form-error">{{error}}</div>
      {{/if}}

      <form method="POST" action="/signin" id="signin-form">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="you@example.com" required>
        </div>
        <div class="form-group" style="margin-bottom: 32px;">
          <label class="form-label" for="password">Password</label>
          <input class="form-input" type="password" id="password" name="password" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Sign In</button>
      </form>

      <p class="form-footer">
        Don't have an account? <a href="/register">Register</a>
      </p>
    </div>
  </section>
</main>

<script type="module" src="/js/form_validate.js"></script>
