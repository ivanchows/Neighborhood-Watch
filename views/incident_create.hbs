<main>
  <section style="padding: 80px 0; min-height: 70vh;">
    <div class="container" style="max-width: 600px;">

      <div style="margin-bottom: 32px;">
        <a href="/incidents" style="color: var(--text-muted); text-decoration: none; font-size: 13px;">← Back to incidents</a>
      </div>

      <div class="section-eyebrow">// Report Incident</div>
      <h2 class="section-title" style="margin-bottom: 36px;">File a new <em>report.</em></h2>

      <div class="panel" style="padding: 36px;">
        <form id="incident_create-form" action="/incident_create" method="POST" style="display: flex; flex-direction: column; gap: 20px;">

          <div>
            <label for="category" style="display: block; margin-bottom: 6px; color: var(--text-muted); font-size: 13px;">Category</label>
            <select name="category" id="category" style="width: 100%; padding: 12px 14px; background: var(--surface-2); border: 1px solid var(--border); color: var(--text); font-size: 14px; border-radius: 6px; outline: none;">
              <option value="">Select a category</option>
              <option value="Suspicious Activity">Suspicious Activity</option>
              <option value="Theft">Theft</option>
              <option value="Vandalism">Vandalism</option>
              <option value="Traffic">Traffic</option>
              <option value="Noise">Noise</option>
              <option value="Animal">Animal</option>
              <option value="Infrastructure">Infrastructure</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label for="Title" style="display: block; margin-bottom: 6px; color: var(--text-muted); font-size: 13px;">Title</label>
            <input type="text" name="Title" id="Title" placeholder="Brief title for the incident" maxlength="100"
              style="width: 100%; padding: 12px 14px; background: var(--surface-2); border: 1px solid var(--border); color: var(--text); font-size: 14px; border-radius: 6px; outline: none;">
          </div>

          <div>
            <label for="description" style="display: block; margin-bottom: 6px; color: var(--text-muted); font-size: 13px;">Description</label>
            <textarea name="description" id="description" placeholder="Describe what happened in detail..." maxlength="500" rows="5"
              style="width: 100%; padding: 12px 14px; background: var(--surface-2); border: 1px solid var(--border); color: var(--text); font-size: 14px; border-radius: 6px; outline: none; resize: vertical; font-family: inherit;"></textarea>
          </div>

          <div>
            <label for="location" style="display: block; margin-bottom: 6px; color: var(--text-muted); font-size: 13px;">Location</label>
            <input type="text" name="location" id="location" placeholder="Street address or intersection" maxlength="100"
              style="width: 100%; padding: 12px 14px; background: var(--surface-2); border: 1px solid var(--border); color: var(--text); font-size: 14px; border-radius: 6px; outline: none;">
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 4px;">Submit Report</button>
        </form>
      </div>

    </div>
  </section>
</main>
